{
    # Enable the FrankenPHP module globally
    frankenphp
    # Disable the admin API to prevent host conflicts on Render
    admin off
}

# Listen on port 8080 (unprivileged port for Render)
:8080 {
    root * /app/public
    encode gzip
    
    # Enable the FrankenPHP server
    php_server
    
    # Handle static files
    file_server
}